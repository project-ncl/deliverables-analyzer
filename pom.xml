        <groupId>org.jboss.pnc</groupId>
        <artifactId>dto</artifactId>
        <version>${version.pnc}</version>
        <classifier>jakarta</classifier>
        <exclusions>
          <exclusion>
            <groupId>org.jboss.pnc</groupId>
